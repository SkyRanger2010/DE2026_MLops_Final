# ==============================
# Этап 1: MLflow
# ==============================
MLFLOW_POSTGRES_USER=mlflow
MLFLOW_POSTGRES_PASSWORD=mlflow123
MLFLOW_POSTGRES_DB=mlflow
MLFLOW_ARTIFACT_ROOT=/mlflow/artifacts

# ==============================
# Этап 2: Airflow
# ==============================
AIRFLOW_POSTGRES_USER=airflow
AIRFLOW_POSTGRES_PASSWORD=airflow123
AIRFLOW_POSTGRES_DB=airflow
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

# ==============================
# Этап 3: LakeFS
# ==============================
LAKEFS_POSTGRES_USER=lakefs
LAKEFS_POSTGRES_PASSWORD=lakefs123
LAKEFS_POSTGRES_DB=lakefs
LAKEFS_AUTH_SECRET=change-this-secret-key-to-something-random
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# ==============================
# Этап 4: JupyterHub
# ==============================
JUPYTERHUB_CRYPT_KEY=generate-a-random-key-here-use-openssl-rand-hex-32

# ==============================
# Этап 5: ML-сервис
# ==============================
MLSERVICE_POSTGRES_USER=mlservice
MLSERVICE_POSTGRES_PASSWORD=mlservice123
MLSERVICE_POSTGRES_DB=mlservice
MODEL_VERSION=1.0.0

# ==============================
# Этап 6: Мониторинг
# ==============================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ==============================
# Этап 9: Prompt Storage (новый MLflow)
# ==============================
PROMPT_MLFLOW_POSTGRES_USER=mlflow_prompt
PROMPT_MLFLOW_POSTGRES_PASSWORD=mlflow_prompt123
PROMPT_MLFLOW_POSTGRES_DB=mlflow_prompt
